{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "yeonhoo",
  "version": "0.1.0",
  "identifier": "dev.yeonhoo.app",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Yeonhoo Terminal",
        "width": 1200,
        "height": 800,
        "minWidth": 600,
        "minHeight": 400,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    },
    "shortDescription": "Claude Code optimized terminal emulator",
    "longDescription": "Yeonhoo is a next-generation terminal emulator built for Claude Code, featuring smart paste, split panes, session restore, and a plugin system.",
    "copyright": "Copyright 2026 Jason Moon",
    "category": "DeveloperTool",
    "publisher": "Jason Moon"
  }
}
